rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /facilities/{facilityId} {
      allow read: if true;
      allow write: if true;
    }

    match /tokens/{tokenId} {
      allow read: if true;
      allow write: if true;
    }

    match /serviceLogs/{logId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
